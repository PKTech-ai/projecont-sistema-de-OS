# Base de dados (Sistema de OS — Postgres separado do Contábil Pro; nunca usar migrate reset em produção)
DATABASE_URL="postgresql://user:pass@localhost:5432/chamados_os"

# NextAuth (gerar com: openssl rand -base64 32)
AUTH_SECRET="cole_aqui_o_auth_secret"

# URL pública do OS (produção PK Tech)
NEXTAUTH_URL="https://tickets.pktech.ai"

# Mesmo JWT_SECRET que na API do Contábil Pro (validação do cookie contabil_session)
JWT_SECRET="mesmo_segredo_que_no_contabil_pro_server"

# Webhooks vindos do Contábil Pro (header x-api-key)
WEBHOOK_SECRET="mesmo_valor_que_WEBHOOK_SECRET_no_CP"

# Link para login do Contábil Pro (sidebar / página de login do OS)
NEXT_PUBLIC_CONTABIL_LOGIN_URL="https://contabil-pro-v2.pktech.ai/login"

# Cron jobs (POST /api/cron/reconcile e /api/cron/reconcile-vinculos com Authorization: Bearer ...)
CRON_SECRET="segredo_para_cron"

# Push notifications (notificações desktop mesmo com browser fechado)
# Gerar chaves: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="cole_aqui_a_chave_publica_vapid"
VAPID_PRIVATE_KEY="cole_aqui_a_chave_privada_vapid"
VAPID_SUBJECT="mailto:admin@pktech.ai"
# A chave pública precisa ser acessível no frontend:
NEXT_PUBLIC_VAPID_PUBLIC_KEY="cole_aqui_a_mesma_chave_publica_vapid"
