generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ANALISTA
  GESTOR
  SAC
  SUPERADMIN
  TV
}

enum StatusChamado {
  NAO_INICIADO
  EM_ANDAMENTO
  AGUARDANDO_VALIDACAO
  CONCLUIDO
  CANCELADO
}

enum Prioridade {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

// GLPI-inspired: tipo de chamado
enum TipoChamado {
  INCIDENTE    // algo parou de funcionar / está errado
  SOLICITACAO  // pedido de serviço / demanda nova
}

enum TipoSetor {
  CONTABIL
  FISCAL
  DP
  IA
  CLIENTES
  /** Contratos, atas, alterações societárias — costuma ser um único responsável para todas as empresas */
  SOCIETARIO
}

/** Classificação do comentário no chat (filtros futuros / base de conhecimento) */
enum TipoMensagemChat {
  NORMAL
  ACAO_SOLICITANTE
  RESOLUCAO
}

model Usuario {
  id        String   @id @default(cuid())
  nome      String   @default("")
  /// Login principal (ex: karina.melo) — único quando preenchido
  username  String?  @unique
  email     String   @unique
  senha     String
  role      Role     @default(ANALISTA)
  ativo     Boolean  @default(true)
  setorId   String
  setor     Setor    @relation(fields: [setorId], references: [id])
  criadoEm  DateTime @default(now())

  /** true = utilizador nunca alterou a senha; redirecionar para /alterar-senha */
  primeiroAcesso Boolean @default(true)

  /** Sincronizado a partir do Contábil Pro (fonte de verdade) */
  origemContabilPro Boolean   @default(false)
  sincronizadoEm    DateTime?

  telefone    String?
  cargo       String?
  observacoes String? @db.Text

  /** Assinatura de push Web (JSON serializado) para notificações desktop mesmo com aba fechada */
  pushSubscription String? @db.Text

  chamadosAbertos     Chamado[]       @relation("Solicitante")
  chamadosResponsavel Chamado[]       @relation("Responsavel")
  comentarios         Comentario[]
  notificacoes        Notificacao[]
  logPersonas         LogPersona[]
  historicoStatus     HistoricoStatus[]
  vinculos            VinculoEmpresa[]
  anexosChamado       AnexoChamado[]
}

model Setor {
  id        String    @id @default(cuid())
  nome      String
  tipo      TipoSetor @unique
  usuarios  Usuario[]
  projetos  Projeto[]
  chamados  Chamado[]
}

model Empresa {
  id        String           @id @default(cuid())
  nome      String
  ativo     Boolean          @default(true)
  criadoEm  DateTime         @default(now())

  /** Sincronizado a partir do Contábil Pro (fonte de verdade) */
  origemContabilPro Boolean   @default(false)
  sincronizadoEm    DateTime?

  /** CNPJ apenas dígitos (14) — único quando informado */
  cnpj         String?  @unique
  razaoSocial  String?
  nomeFantasia String?
  emailContato String?
  telefone     String?
  cep          String?
  logradouro   String?
  numero       String?
  complemento  String?
  bairro       String?
  cidade       String?
  uf           String?
  observacoes  String? @db.Text

  /** IDs originais dos responsáveis vindo do Contábil Pro.
   *  Guardados para reconciliação posterior caso o usuário ainda não existisse no OS
   *  quando o webhook de empresa chegou. */
  fiscalContabilId      String?
  rhContabilId          String?
  societarioContabilId  String?

  vinculos  VinculoEmpresa[]
  chamados  Chamado[]
  logPersonas LogPersona[]
}

model VinculoEmpresa {
  id            String  @id @default(cuid())
  empresaId     String
  empresa       Empresa @relation(fields: [empresaId], references: [id])
  tipoServico   String
  responsavelId String
  responsavel   Usuario @relation(fields: [responsavelId], references: [id])

  @@unique([empresaId, tipoServico])
}

model Projeto {
  id        String   @id @default(cuid())
  nome      String
  descricao String?
  ativo     Boolean  @default(true)
  setorId   String
  setor     Setor    @relation(fields: [setorId], references: [id])
  criadoEm  DateTime @default(now())
  chamados  Chamado[]
}

model Chamado {
  id              String        @id @default(cuid())
  titulo          String
  descricao       String
  status          StatusChamado @default(NAO_INICIADO)
  prioridade      Prioridade    @default(MEDIA)
  autoFechado     Boolean       @default(false)
  emNomeDeCliente Boolean       @default(false)

  tipo    TipoChamado @default(SOLICITACAO)
  solucao String? // preenchido pelo analista ao entregar

  // Setor de destino — para roteamento e regras de UI
  setorDestinoId  String?
  setorDestino    Setor?        @relation(fields: [setorDestinoId], references: [id])

  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt
  prazoSla     DateTime?
  entregueEm   DateTime?
  concluidoEm  DateTime?

  solicitanteId String
  solicitante   Usuario  @relation("Solicitante", fields: [solicitanteId], references: [id])
  responsavelId String
  responsavel   Usuario  @relation("Responsavel", fields: [responsavelId], references: [id])

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id])

  /** Entrega para validação dentro do prazo (previsão na abertura) */
  entregaNoPrazo    Boolean?
  /** Conclusão pelo solicitante dentro do prazo */
  conclusaoNoPrazo  Boolean?
  projetoId String?
  projeto   Projeto? @relation(fields: [projetoId], references: [id])

  comentarios     Comentario[]
  notificacoes    Notificacao[]
  historicoStatus HistoricoStatus[]
  logPersonas     LogPersona[]
  anexos          AnexoChamado[]

  @@index([status])
  @@index([responsavelId])
  @@index([solicitanteId])
  @@index([empresaId])
}

model AnexoChamado {
  id             String   @id @default(cuid())
  nomeOriginal   String
  mimeType       String?
  tamanhoBytes   Int
  /** Caminho relativo à pasta uploads/chamados (ex.: chamadoId/uuid-nome.pdf) */
  storageKey     String   @unique
  criadoEm       DateTime @default(now())
  chamadoId      String
  chamado        Chamado  @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  autorId        String
  autor          Usuario  @relation(fields: [autorId], references: [id])

  @@index([chamadoId])
}

model Comentario {
  id        String           @id @default(cuid())
  conteudo  String
  tipo      TipoMensagemChat @default(NORMAL)
  criadoEm  DateTime         @default(now())
  chamadoId String
  chamado   Chamado          @relation(fields: [chamadoId], references: [id])
  autorId   String
  autor     Usuario          @relation(fields: [autorId], references: [id])
}

model Notificacao {
  id        String   @id @default(cuid())
  tipo      String
  lida      Boolean  @default(false)
  criadoEm  DateTime @default(now())
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  chamadoId String
  chamado   Chamado  @relation(fields: [chamadoId], references: [id])
}

model HistoricoStatus {
  id            String        @id @default(cuid())
  statusAntes   StatusChamado
  statusDepois  StatusChamado
  justificativa String?
  criadoEm      DateTime      @default(now())
  chamadoId     String
  chamado       Chamado       @relation(fields: [chamadoId], references: [id])
  atorId        String
  ator          Usuario       @relation(fields: [atorId], references: [id])

  @@index([chamadoId])
}

model LogPersona {
  id        String   @id @default(cuid())
  criadoEm  DateTime @default(now())
  atorId    String
  ator      Usuario  @relation(fields: [atorId], references: [id])
  empresaId String
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  chamadoId String
  chamado   Chamado  @relation(fields: [chamadoId], references: [id])
}
